# See README.md → "Where each variable comes from" for sourcing each value.


# Optional: wei amount minted to deployer in `DeployMockAssetSepolia.s.sol` (default 1_000_000 * 10^18)
# MOCK_ASSET_MINT_AMOUNT=

# Get from https://etherscan.io/apis (works for Sepolia verification via Foundry)
# ETHERSCAN_API_KEY=

# Required for `script/DeploySepolia.s.sol` (see README.md → "Where each variable comes from")
# PRIVATE_KEY=        # hex with or without 0x prefix
# SEPOLIA_RPC_URL=https://rpc.sepolia.org
# ASSET_TOKEN=        # Sepolia ERC-20 used as vault asset (Etherscan / token docs), not the router
# Ethereum Sepolia Functions router (verify on Chainlink docs — may change):
# FUNCTIONS_ROUTER=0xb83E47C2bC239B3bf370bc41e1459A34b41238D0

# Optional: Chainlink Functions — used by script/SendFunctionsSettlement.s.sol
# FUNCTIONS_SETTLEMENT=     # same as deployed consumer
# FUNCTIONS_SUBSCRIPTION_ID=
# SETTLEMENT_TOKEN_ID=1
# FUNCTIONS_REPAY_WEI=1000000000000000000
# FUNCTIONS_CALLBACK_GAS_LIMIT=500000
# FUNCTIONS_DON_ID=0x66756e2d657468657265756d2d7365706f6c69612d3100000000000000000000
# FUNCTIONS_JS_PATH=script/chainlink/functions-settlement-source.js  # SendFunctionsSettlementWithRepay only
# FUNCTIONS_JS_LEGACY_FILE=   # optional custom file for SendFunctionsSettlement (legacy one-arg)

# `script/DevSmoke.s.sol` — addresses from `DeployLocal` broadcast logs
# RECEIVABLE=
# VAULT=
# SELLER=
