# Copy to `.env` for Foundry scripts. Never commit `.env`.
# See README for where each value comes from.

# Optional: wei amount minted to deployer in `DeployMockAssetSepolia.s.sol`
# MOCK_ASSET_MINT_AMOUNT=

# Etherscan API key (Sepolia verification)
# ETHERSCAN_API_KEY=

# Deploy / broadcast (uncomment and fill)
# PRIVATE_KEY=
# SEPOLIA_RPC_URL=
# ASSET_TOKEN=
# FUNCTIONS_ROUTER=

# Chainlink Functions — `SendFunctionsSettlement*.s.sol`
# FUNCTIONS_SETTLEMENT=
# FUNCTIONS_SUBSCRIPTION_ID=
# SETTLEMENT_TOKEN_ID=
# FUNCTIONS_REPAY_WEI=
# FUNCTIONS_CALLBACK_GAS_LIMIT=
# FUNCTIONS_DON_ID=
# FUNCTIONS_JS_PATH=script/chainlink/functions-settlement-source.js
# FUNCTIONS_JS_LEGACY_FILE=

# `script/DevSmoke.s.sol` — from local deploy broadcast output
# RECEIVABLE=
# VAULT=
# SELLER=
