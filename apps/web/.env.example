# Copy to .env and restart `npm run dev` after changes.

# Optional: GitHub repo URL for header links (defaults to sp0oby/receivable-factoring-smart-contracts)
# VITE_GITHUB_REPO_URL=https://github.com/you/your-fork

# FactoringVault
VITE_VAULT_ADDRESS=0x4601B97eE914FDcd571546D48d6D5330B28928e4

# Sepolia deployment: OperatorOracle / FactoringAutomation / FunctionsSettlement (for full UI)
VITE_OPERATOR_ORACLE=0xf0a7AA9d95793DA05Ec07EAe5DDa23C1982AF0E8
VITE_AUTOMATION=0xaa0beeAcCDE24B6e2783181b9A1326f25120A800
VITE_FUNCTIONS_SETTLEMENT=0xa061E09e19e636E4B27D76c2fe62a7A9D160b760

# Chainlink Functions router (display / your own Functions calls)
VITE_FUNCTIONS_ROUTER=0xb83E47C2bC239B3bf370bc41e1459A34b41238D0

# 11155111 = Sepolia (default if omitted). Use 31337 for local Anvil.
# VITE_CHAIN_ID=11155111

# Optional: browser RPC (any API key in a VITE_ var is public to clients)
# VITE_SEPOLIA_RPC=
