# Copy to `apps/web/.env` and restart `npm run dev` after changes.
# Never commit `.env`. Addresses come from your deploy or the README tables.

# Optional: override header link to your fork
# VITE_GITHUB_REPO_URL=https://github.com/your-org/your-repo

# Required for most of the demo UI (FactoringVault)
# VITE_VAULT_ADDRESS=0x

# Optional — operator panel, automation button, Functions display
# VITE_OPERATOR_ORACLE=0x
# VITE_AUTOMATION=0x
# VITE_FUNCTIONS_SETTLEMENT=0x

# Display-only (Chainlink Functions router on your network)
# VITE_FUNCTIONS_ROUTER=0x

# 11155111 = Sepolia (default if omitted). Use 31337 for Anvil.
# VITE_CHAIN_ID=11155111

# Optional browser RPC (treat as public if it embeds a key)
# VITE_SEPOLIA_RPC=
